<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.MainActivity">

    <LinearLayout
        android:layout_width="640dp"
        android:layout_height="356dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:textAlignment="center"
            app:srcCompat="@drawable/logopolyhome" />

        <LinearLayout
            android:layout_width="377dp"
            android:layout_height="356dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Se connecter:"
                android:textAlignment="center"
                android:textColor="#0160C8"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/errorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#FF0000" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="357dp"
                android:layout_height="74dp"
                android:hint="Identifiant"
                app:startIconDrawable="@drawable/ic_id">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/LoginInput"
                    android:layout_width="357dp"
                    android:layout_height="60dp"
                    android:paddingStart="60dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="359dp"
                android:layout_height="74dp"
                android:layout_marginTop="16dp"
                android:hint="Mot de passe"
                app:endIconMode="password_toggle"
                app:startIconDrawable="@drawable/ic_mdp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/mdpInput"
                    android:layout_width="357dp"
                    android:layout_height="61dp"
                    android:inputType="textPassword"
                    android:paddingStart="60dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="Pas encore inscrit?" />

            <Button
                android:id="@+id/buttonInscription"
                android:layout_width="158dp"
                android:layout_height="wrap_content"
                android:background="#00FFFFFF"
                android:onClick="registerNewAccount"
                android:text="Inscrivez-vous"
                android:textColor="#015FC8" />
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>