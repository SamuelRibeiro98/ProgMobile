<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00D1F0">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="676dp"
        android:layout_height="231dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <!-- Bouton Maison -->

        <androidx.cardview.widget.CardView
            android:layout_width="200dp"
            android:layout_height="match_parent"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="50dp"
            app:cardElevation="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnControl"
                android:layout_width="200dp"

                android:layout_height="match_parent"
                android:onClick="controlHouse"
                android:paddingTop="20dp"
                android:text="@string/ctrlMaison"
                android:textAllCaps="false"

                android:textColor="#2551AF"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/transparent"
                app:icon="@drawable/control_maison"
                app:iconGravity="top"
                app:iconSize="80dp"
                app:iconTint="@null" />

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="50dp"
            app:cardElevation="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDroits"
                android:layout_width="200dp"
                android:layout_height="match_parent"

                android:onClick="openRights"
                android:paddingTop="20dp"
                android:text="@string/donnerDroits"
                android:textAllCaps="false"

                android:textColor="#2551AF"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/transparent"
                app:icon="@drawable/droits"
                app:iconGravity="top"
                app:iconSize="80dp"
                app:iconTint="@null" />

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="200dp"
            android:layout_height="match_parent"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="50dp"
            app:cardElevation="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAcces"
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:onClick="openOtherHouses"

                android:paddingTop="15dp"
                android:text="@string/accesAutresMaisons"
                android:textAllCaps="false"
                android:textColor="#2551AF"
                android:textSize="20sp"

                android:textStyle="bold"
                app:backgroundTint="@android:color/transparent"
                app:icon="@drawable/acces"
                app:iconGravity="top"
                app:iconPadding="0dp"
                app:iconSize="90dp"
                app:iconTint="@null" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="@string/titreMenu"
        android:textColor="#2551AF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDeconnexion"
        android:layout_width="171dp"
        android:layout_height="64dp"
        android:layout_marginTop="5dp"
        android:paddingTop="10dp"
        android:text="@string/btnDeconnexion"
        android:textAllCaps="false"
        android:textColor="#2551AF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:onClick="logout"
        app:backgroundTint="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout" />

    <TextView
        android:id="@+id/idHouse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="ID de votre maison : "
        android:textColor="#2551AF"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3" />
</androidx.constraintlayout.widget.ConstraintLayout>
