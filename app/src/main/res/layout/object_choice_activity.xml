<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00D1F0">

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="368dp"
        android:layout_height="545dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <androidx.cardview.widget.CardView
            android:layout_width="330dp"
            android:layout_height="150dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="12dp" >

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShutters"
                android:layout_width="match_parent"

                android:layout_height="match_parent"
                android:onClick="controlShutters"
                android:paddingTop="20dp"
                android:text="@string/ctrlVolets"
                android:textAllCaps="false"

                android:textColor="#2551AF"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/transparent"
                app:icon="@drawable/volets"
                app:iconGravity="start"
                app:iconSize="80dp"
                app:iconTint="@null" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="330dp"
            android:layout_height="150dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="12dp" >

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLights"
                android:layout_width="match_parent"

                android:layout_height="match_parent"
                android:onClick="controlLights"
                android:paddingTop="20dp"
                android:text="@string/ctrlLumieres"
                android:textAllCaps="false"

                android:textColor="#2551AF"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/transparent"
                app:icon="@drawable/lumieres"
                app:iconGravity="start"
                app:iconSize="80dp"
                app:iconTint="@null" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="330dp"
            android:layout_height="150dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="12dp" >

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGarages"
                android:layout_width="match_parent"

                android:layout_height="match_parent"
                android:onClick="controlGarage"
                android:paddingTop="20dp"
                android:text="@string/ctrlGarages"
                android:textAllCaps="false"

                android:textColor="#2551AF"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/transparent"
                app:icon="@drawable/garage"
                app:iconGravity="start"
                app:iconSize="80dp"
                app:iconTint="@null" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <TextView
        android:id="@+id/textView5"
        android:layout_width="370dp"
        android:layout_height="39dp"
        android:layout_marginBottom="10dp"
        android:gravity="center"
        android:text="Choisissez le type d'appareil à contrôler:"
        android:textColor="#2551AF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRetour"
        android:layout_width="171dp"
        android:layout_height="64dp"
        android:layout_marginTop="10dp"
        android:onClick="goBack"
        android:paddingTop="10dp"
        android:text="@string/btnRetour"
        android:textAllCaps="false"
        android:textColor="#2551AF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout2" />

</androidx.constraintlayout.widget.ConstraintLayout>